# ---------------------------------------------------------------------------
# Project data & generated artifacts
# ---------------------------------------------------------------------------
# Published SeisBench dataset (~35 GB) and StationXML response archive
# (~80 MB) — distributed separately on Zenodo, not in git.
data/

# Run outputs: figures, per-event tables, MiniSEED exports.
outputs/

# Local training outputs (per-epoch ckpts + train.log + history.json). The
# *published* checkpoints live under application/seisbench-rose-benchmark/
# models/ and are versioned; this dir is whatever was produced on this machine.
checkpoints/

# Local benchmark outputs (per-run JSON / CSV / log / viz PNGs under eval/<run>/).
# The *published* benchmark numbers live in
# application/seisbench-rose-benchmark/results/.
eval/

# Output of application/seisbench-rose-benchmark/scripts/reproduce_all.sh
# (per-model JSONs + aggregated CSVs). The committed reference numbers are the
# *.csv files directly under results/; only results/runs/ is generated.
# (Full path: a pattern with a mid-slash is anchored to this .gitignore's dir.)
application/seisbench-rose-benchmark/results/runs/

# Derived split index (full train/dev/test assignment for the local copy of the
# RoSE dataset). Regenerated idempotently by
# training/build_rose_split_index.py; the pinned test-set composition is
# committed under application/seisbench-rose-benchmark/data/rose_test_index.csv,
# so the multi-MB full-split file does not need to be versioned.
rose_split_index.csv
rose_split_index.json

# ---------------------------------------------------------------------------
# Excluded from the public dataset-companion repository
# (kept on disk locally; not pushed to GitHub)
# NOTE: .gitignore does NOT support inline comments — keep patterns alone.
# ---------------------------------------------------------------------------
# Manuscript and figures
draft/
# Third-party supplementary PDFs
reference/
# Internal data-prep pipeline (not user-facing).
# Anchored to the repo root so it does NOT also swallow
# application/seisbench-rose-benchmark/scripts/ (the published reproducer).
/scripts/
# Raw StationXML / dataless dumps. Keep only the SC3ML→StationXML
# conversion script for reproducibility of the response-archive build.
# (Negation works only when the parent dir itself isn't ignored, so we
# exclude the contents instead of the directory.)
stationxml_sources/*
!stationxml_sources/sc3ml_niep
stationxml_sources/sc3ml_niep/*
!stationxml_sources/sc3ml_niep/sc3ml_to_stationxml.py
# Engineering ground-motion DB pipeline (separate scope)
gmdb/
# Deprecated tutorial
examples/02_train_phasenet.py
# gmdb tests
tests/test_intensity.py
tests/test_io_rose.py
tests/test_response.py
# gmdb docs
docs/gmdb/
# Internal review artifact
docs/PYTHON_REVIEW.md

# Raw station-inventory dumps. Only the sc3ml_to_stationxml.py script is
# versioned; the source XML archives are derived / re-downloadable.
stationxml_sources/fdsn/
stationxml_sources/sc3ml_niep/*/
stationxml_sources/sc3ml_niep/*.tar.gz*
stationxml_sources/sc3ml_niep/inventory.*

# Generic large-artifact safety net
*.hdf5
*.h5
*.mseed
*.sac
*.npz
*.pt
*.pth
*.ckpt

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
build/
dist/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
.python-version

# Jupyter
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Editors / OS / agent metadata
# ---------------------------------------------------------------------------
.vscode/
.idea/
.claude/
.codex/
.antigravity/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Secrets & local config
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
credentials*.json

# ---------------------------------------------------------------------------
# ML pipeline (training / benchmark / published model release)
# These dirs ARE versioned — re-include them and the few binary artifacts
# (small SeisBench checkpoints + the RED-PAN Keras model) that the generic
# safety-net patterns above would otherwise swallow. Negation rules must come
# after the patterns they override, so they live here at the end of the file.
# ---------------------------------------------------------------------------
!training/
!benchmark/
!application/
# The published benchmark release ships its requirements under env/ and its
# test-set index files / download notes under data/ — un-ignore those specific
# directories (the generic `env/` and `data/` rules above are meant for
# virtualenvs and the multi-GB waveform datasets, respectively).
!application/seisbench-rose-benchmark/env/
!application/seisbench-rose-benchmark/data/
# Bundled model weights in the release (1.6 MB + 1.1 MB SeisBench .pt,
# 5.8 MB RED-PAN Keras .hdf5). Small enough to version with the code.
!application/seisbench-rose-benchmark/models/**/*.pt
!application/seisbench-rose-benchmark/models/**/*.hdf5
