# ---------------------------------------------------------------------------
# Project data & generated artifacts
# ---------------------------------------------------------------------------
# Published SeisBench dataset (~35 GB) and StationXML response archive
# (~80 MB) — distributed separately on Zenodo, not in git.
data/

# Run outputs: figures, per-event tables, MiniSEED exports.
outputs/

# Local training outputs (per-epoch ckpts + train.log + history.json). The
# *published* checkpoints live under models/ and are versioned; this dir is
# whatever was produced on this machine.
checkpoints/

# Local benchmark outputs (per-run JSON / CSV / log / viz PNGs under eval/<run>/).
# The *published* benchmark numbers live in results/.
eval/

# Output of benchmark/run_inference.py (per-model JSONs + aggregated CSVs) lands
# under <eval_dir>/, default eval/ — already ignored above. The committed
# reference numbers are the *.csv files directly under results/, which
# build_leaderboard.py --update-results overwrites. (Older runs used a
# results/runs/ staging dir — kept ignored just in case.)
/phase_picking/results/runs/

# Derived split index (full train/dev/test assignment for the local copy of the
# RoSE dataset). Regenerated idempotently by training/build_rose_split_index.py;
# the pinned test-set composition is committed under
# benchmark/data/rose_test_index.csv, so the multi-MB full-split file does not
# need to be versioned.
rose_split_index.csv
rose_split_index.json

# ---------------------------------------------------------------------------
# Excluded from the public dataset-companion repository
# (kept on disk locally; not pushed to GitHub)
# NOTE: .gitignore does NOT support inline comments — keep patterns alone.
# ---------------------------------------------------------------------------
# Manuscript and figures
draft/
# Third-party supplementary PDFs
reference/
# Internal data-prep pipeline (not user-facing); anchored to the repo root.
/scripts/
# Raw StationXML / dataless dumps. Keep only the SC3ML→StationXML
# conversion script for reproducibility of the response-archive build.
# (Negation works only when the parent dir itself isn't ignored, so we
# exclude the contents instead of the directory.)
stationxml_sources/*
!stationxml_sources/sc3ml_niep
stationxml_sources/sc3ml_niep/*
!stationxml_sources/sc3ml_niep/sc3ml_to_stationxml.py
# Engineering ground-motion DB pipeline (separate scope)
gmdb/
# Deprecated tutorial
examples/02_train_phasenet.py
# gmdb tests
tests/test_intensity.py
tests/test_io_rose.py
tests/test_response.py
# gmdb docs
docs/gmdb/
# Internal review artifact
docs/PYTHON_REVIEW.md

# Raw station-inventory dumps. Only the sc3ml_to_stationxml.py script is
# versioned; the source XML archives are derived / re-downloadable.
stationxml_sources/fdsn/
stationxml_sources/sc3ml_niep/*/
stationxml_sources/sc3ml_niep/*.tar.gz*
stationxml_sources/sc3ml_niep/inventory.*

# Generic large-artifact safety net
*.hdf5
*.h5
*.mseed
*.sac
*.npz
*.pt
*.pth
*.ckpt

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
build/
dist/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
.python-version

# Jupyter
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Editors / OS / agent metadata
# ---------------------------------------------------------------------------
.vscode/
.idea/
.claude/
.codex/
.antigravity/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Secrets & local config
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
credentials*.json

# ---------------------------------------------------------------------------
# ML pipeline (training / benchmark / published checkpoints + results)
# These dirs ARE versioned — re-include the few paths/binaries that the generic
# safety-net patterns above would otherwise swallow. Negation rules must come
# after the patterns they override, so they live here at the end of the file.
# ---------------------------------------------------------------------------
!training/
!phase_picking/benchmark/
# Pinned test-set index CSVs + download notes under benchmark/data/ (the
# generic `data/` rule above is for the multi-GB waveform dataset mount).
!phase_picking/benchmark/data/
# Published checkpoints: 1.6 MB + 1.1 MB SeisBench .pt and the 5.8 MB RED-PAN
# Keras .hdf5 under models/ (the generic `*.pt` / `*.hdf5` rules above are for
# training output). Small enough to version with the code.
!phase_picking/models/**/*.pt
!phase_picking/models/**/*.hdf5
