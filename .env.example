# Copy to `.env` (or `export ...` in your shell) before running the training /
# benchmark scripts. Each variable below is the default value the corresponding
# argparse flag falls back to; you can override per-invocation with the flag.

# Path to the SeisBench-format RoSE waveform dataset (yearly metadata*.csv +
# waveforms*.hdf5). Used by training/* and benchmark/* via --rose-dir.
ROSE_DATA_DIR=/path/to/rose

# Path to the prepared STEAD test directory (metadata.csv, metadata_noise.csv,
# waveforms/, noise_waveforms/). Used by benchmark/bench_stead_test.py and
# benchmark/bench_noise_fp.py via --stead-dir. The exact metadata.csv files
# used to produce the published numbers are pinned under
# application/seisbench-rose-benchmark/data/stead_{test,noise}_index.csv.
STEAD_DIR=/path/to/STEAD/benchmark_stead

# Output directory for training checkpoints + logs + history.json. Used by
# training/train_eqt_rose.py and training/train_phasenet_rose.py via --out-dir.
ROSE_TRAIN_OUT_DIR=checkpoints

# Root directory for benchmark outputs (per-run sub-dirs are created underneath).
# Used by benchmark/build_*.py and benchmark/viz_models_rose.py.
ROSE_EVAL_DIR=eval
